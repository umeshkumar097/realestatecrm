generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agency {
  id                   String              @id @default(cuid())
  name                 String
  domain               String?             @unique
  logo                 String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  customDomain         String?             @unique
  planId               String?
  status               AgencyStatus        @default(ACTIVE)
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  billingAddress       String?
  billingEmail         String?
  gstNumber            String?
  apiKey               String?             @unique
  apiUsageCount        Int                 @default(0)
  activities           Activity[]
  plan                 SubscriptionPlan?   @relation(fields: [planId], references: [id])
  emis                 EMI[]
  googleSheets         GoogleSheetSync?
  leads                Lead[]
  messages             Message[]
  platformInvoices     PlatformInvoice[]
  portalIntegrations   PortalIntegration[]
  projects             Project[]
  properties           Property[]
  subscription         Subscription?
  tasks                Task[]
  tickets              Ticket[]
  users                User[]
  webhookConfigs       WebhookConfig[]
  whatsappSessions     WhatsAppSession[]
}

model PlatformInvoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  sequenceNumber Int
  amount         Float
  currency       String        @default("INR")
  status         InvoiceStatus @default(PAID)
  planSnapshot   String?
  generatedAt    DateTime      @default(now())
  agencyId       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  agency         Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String?
  role            UserRole         @default(AGENT)
  agencyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  attendance      Json?
  commission      Float?
  emailVerified   DateTime?
  activities      Activity[]
  leads           Lead[]           @relation("AssignedLeads")
  tasks           Task[]
  tickets         Ticket[]
  agency          Agency?          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  whatsappSession WhatsAppSession?
}

model WhatsAppSession {
  id          String   @id @default(cuid())
  agentId     String   @unique
  agencyId    String
  sessionData String
  status      String   @default("DISCONNECTED")
  phoneNumber String?
  qrCode      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agent       User     @relation(fields: [agentId], references: [id])
}

model Lead {
  id           String     @id @default(cuid())
  name         String?
  email        String?
  phone        String
  source       String?    @default("WHATSAPP")
  status       LeadStatus @default(NEW)
  priority     Int        @default(1)
  agencyId     String
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  budget       String?
  location     String?
  notes        String?
  propertyType String?
  activities   Activity[]
  emis         EMI[]
  agency       Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  messages     Message[]
  tickets      Ticket[]

  @@unique([phone, agencyId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  content   String
  leadId    String
  userId    String
  agencyId  String
  createdAt DateTime @default(now())
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lead      Lead     @relation(fields: [leadId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  location    String
  agencyId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  emis        EMI[]
  agency      Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  properties  Property[]
  tickets     Ticket[]
}

model EMI {
  id                String        @id @default(cuid())
  leadId            String
  projectId         String
  plotNumber        String
  plotRate          Float
  totalPrice        Float
  planDetails       String?
  startDate         DateTime
  expiryDate        DateTime
  status            String        @default("ACTIVE")
  agencyId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  frequency         String        @default("MONTHLY")
  installmentAmount Float         @default(0)
  nextDueDate       DateTime?
  totalInstallments Int           @default(1)
  agency            Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lead              Lead          @relation(fields: [leadId], references: [id])
  project           Project       @relation(fields: [projectId], references: [id])
  installments      Installment[]
}

model Installment {
  id        String   @id @default(cuid())
  emiId     String
  amount    Float
  dueDate   DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emi       EMI      @relation(fields: [emiId], references: [id])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("TODAY")
  dueDate      DateTime?
  assignedToId String
  agencyId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignedTo   User      @relation(fields: [assignedToId], references: [id])
}

model Ticket {
  id           String   @id @default(cuid())
  subject      String
  description  String?
  type         String   @default("SUPPORT")
  status       String   @default("OPEN")
  leadId       String
  projectId    String?
  assignedToId String?
  agencyId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  lead         Lead     @relation(fields: [leadId], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  fromMe    Boolean
  timestamp DateTime @default(now())
  leadId    String
  agencyId  String
  senderId  String?
  createdAt DateTime @default(now())
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model Property {
  id          String         @id @default(cuid())
  title       String
  description String?
  price       Float
  address     String
  city        String
  state       String
  zip         String
  beds        Int?
  baths       Float?
  area        Float?
  type        PropertyType
  status      PropertyStatus @default(AVAILABLE)
  images      String[]
  agencyId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  projectId   String?
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id])
}

model Subscription {
  id                   String             @id @default(cuid())
  agencyId             String             @unique
  plan                 String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  agency               Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  monthlyPrice    Float
  yearlyPrice     Float
  maxAgents       Int      @default(5)
  maxLeads        Int      @default(1000)
  features        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stripePriceId   String?  @unique
  stripeProductId String?  @unique
  isPublic        Boolean  @default(true)
  agencies        Agency[]
  coupons         Coupon[]
}

model Coupon {
  id        String           @id @default(cuid())
  code      String           @unique
  planId    String
  isActive  Boolean          @default(true)
  maxUses   Int              @default(1)
  usedCount Int              @default(0)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
}

model SystemLog {
  id        String   @id @default(cuid())
  type      String
  level     String   @default("INFO")
  action    String
  details   Json?
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id              String   @id @default("global")
  aiExtraction    Boolean  @default(true)
  freeTrialDays   Int      @default(14)
  maintenanceMode Boolean  @default(false)
  publicSignup    Boolean  @default(true)
  supportEmail    String   @default("support@aiclex.in")
  updatedAt       DateTime @updatedAt
}

model PlatformLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  message   String?
  plan      String   @default("Enterprise")
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalIntegration {
  id         String   @id @default(cuid())
  name       String
  apiKey     String?
  webhookUrl String?
  status     String   @default("ACTIVE")
  agencyId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model WebhookConfig {
  id        String   @id @default(cuid())
  agencyId  String
  name      String   @default("Default Webhook")
  secret    String   @unique @default(cuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model GoogleSheetSync {
  id            String    @id @default(cuid())
  agencyId      String    @unique
  spreadsheetId String?
  sheetName     String    @default("Leads")
  accessToken   String?
  refreshToken  String?
  isActive      Boolean   @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  agency        Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  PAID
  UNPAID
  VOID
  ZERO
}

enum AgencyStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DELETED
}

enum UserRole {
  ADMIN
  AGENT
  SUPER_ADMIN
  AGENCY_OWNER
}

enum LeadStatus {
  NEW
  CONNECTED
  NOT_CONNECTED
  QUALIFIED
  NOT_QUALIFIED
  SITE_VISIT
  CONVERTED
  LOST
}

enum PropertyStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}
